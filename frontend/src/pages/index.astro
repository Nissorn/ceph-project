---
import ThemeToggle from '../components/ui/ThemeToggle';
import DashboardApp from '../components/ui/DashboardApp';
import '../styles/global.css';
---

<html lang="en" class="dark">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <title>Singapodent | Cephalometric Analysis</title>
    <!-- Runs synchronously before paint: removes dark only if user explicitly chose light -->
    <script is:inline>
      (function () {
        if (localStorage.getItem('theme') === 'light') {
          document.documentElement.classList.remove('dark');
        }
      })();
    </script>
  </head>
  <body class="h-screen overflow-hidden flex flex-col bg-slate-50 dark:bg-slate-900 transition-colors duration-300 text-slate-900 dark:text-slate-100 antialiased selection:bg-singapodent-accent selection:text-white" style="font-family: 'Plus Jakarta Sans', sans-serif;">

    <header class="bg-white dark:bg-slate-900 border-b border-slate-200 dark:border-slate-800/70 z-50 transition-colors duration-300 relative">
      <div class="max-w-[1600px] w-full mx-auto px-6 h-[72px] flex items-center justify-between">
        <div class="flex items-center gap-3 group cursor-default">
          <div class="dark:bg-white/95 dark:px-3 dark:py-1.5 dark:rounded-xl transition-all duration-300 dark:shadow-md flex items-center justify-center">
            <img src="/logo.webp" alt="Singapodent Logo" class="h-8 md:h-10 w-auto object-contain transition-transform duration-300 group-hover:scale-[1.02] drop-shadow-sm" />
          </div>
          <span class="font-light text-singapodent-accent text-xs md:text-sm tracking-wide uppercase border-l border-slate-200 dark:border-slate-800 pl-3 self-center hidden sm:inline">AI Dashboard</span>
        </div>
        <div class="flex items-center space-x-4">
          <ThemeToggle client:load />
        </div>
      </div>
    </header>

    <main class="flex-1 overflow-hidden w-full mx-auto max-w-[1600px] p-6 pt-8">
      <DashboardApp client:load />
    </main>
    
    <style>
      /* Quick global overrides specifically to enhance the premium feel */
      .custom-scrollbar::-webkit-scrollbar {
        width: 6px;
      }
      .custom-scrollbar::-webkit-scrollbar-track {
        background: transparent;
      }
      .custom-scrollbar::-webkit-scrollbar-thumb {
        background-color: rgba(156, 163, 175, 0.3);
        border-radius: 10px;
      }
    </style>
  </body>
</html>
